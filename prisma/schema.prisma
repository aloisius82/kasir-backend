generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  username         String            @unique
  password         String
  role             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastActive       DateTime?
  lastLogin        DateTime?
  status           UserStatus        @default(active)
  token            String?
  order            Order[]
  penerimaan       Penerimaan[]
  penjualan        Penjualan[]
  transaksiBarangs transaksiBarang[]
  stockOpnames     StockOpname[]
}

model Kategori {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barang    Barang[]
}

model Barang {
  id                 Int                 @id @default(autoincrement())
  nama               String
  deskripsi          String?
  hargaJual          Decimal
  hargaBeli          Decimal
  hargaBeliTerakhir  Decimal
  hpp                Decimal
  barcode            String?             @unique
  kategoriId         Int
  saleLokasiId       Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  qty                Int                 @default(0)
  kategori           Kategori            @relation(fields: [kategoriId], references: [id])
  saleLokasi         Lokasi?             @relation(fields: [saleLokasiId], references: [id])
  detailOrder        DetailOrder[]
  detailPenerimaan   DetailPenerimaan[]
  detailPenjualan    DetailPenjualan[]
  stok               Stok[]
  inactive           Boolean             @default(false)
  transaksiBarangs   transaksiBarang[]
  detailStockOpnames DetailStockOpname[]

  @@index([kategoriId], map: "Barang_kategoriId_fkey")
  @@index([saleLokasiId], map: "Barang_saleLokasiId_fkey")
}

model Penjualan {
  id              Int               @id @default(autoincrement())
  tanggal         DateTime          @default(now())
  userId          Int
  total           Decimal
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  session         Int
  discountAmount  Decimal           @default(0.000000000000000000000000000000)
  discountPercent Decimal           @default(0.000000000000000000000000000000)
  discountRef     String?           
  paymentType     PaymentType       @default(cash)
  paymentRef      String?           
  detailPenjualan DetailPenjualan[]
  user            User              @relation(fields: [userId], references: [id])

  @@index([userId], map: "Penjualan_userId_fkey")
}

model DetailPenjualan {
  id                     Int       @id @default(autoincrement())
  penjualanId            Int
  barangId               Int
  jumlah                 Int
  hargaSatuan            Decimal
  hpp                    Decimal
  subtotal               Decimal
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  discountAmount         Decimal   @default(0.000000000000000000000000000000)
  discountPercent        Decimal   @default(0.000000000000000000000000000000)
  subtotalBeforeDiscount Decimal   @default(0.000000000000000000000000000000)
  barang                 Barang    @relation(fields: [barangId], references: [id])
  penjualan              Penjualan @relation(fields: [penjualanId], references: [id])

  @@index([barangId], map: "DetailPenjualan_barangId_fkey")
  @@index([penjualanId], map: "DetailPenjualan_penjualanId_fkey")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  nama      String
  alamat    String?
  telepon   String?
  pic       String?
  picPhone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order[]
}

model Order {
  id          Int           @id @default(autoincrement())
  tanggal     DateTime      @default(now())
  noReferensi String
  supplierId  Int
  userId      Int
  total       Decimal
  remark      String?
  status      StatusOrder
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  detailOrder DetailOrder[]
  supplier    Supplier      @relation(fields: [supplierId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  Penerimaan  Penerimaan[]

  @@index([supplierId], map: "Order_supplierId_fkey")
  @@index([userId], map: "Order_userId_fkey")
}

model DetailOrder {
  id        Int      @id @default(autoincrement())
  orderId   Int
  barangId  Int
  jumlah    Int
  hargaBeli Decimal
  subtotal  Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barang    Barang   @relation(fields: [barangId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])

  @@index([barangId], map: "DetailOrder_barangId_fkey")
  @@index([orderId], map: "DetailOrder_orderId_fkey")
}

model Penerimaan {
  id               Int                @id @default(autoincrement())
  tanggal          DateTime           @default(now())
  userId           Int
  total            Decimal
  noReferensi      String?
  orderId          Int?
  pengirim         String?
  remark           String?
  status           StatusPenerimaan
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  detailPenerimaan DetailPenerimaan[]
  order            Order?             @relation(fields: [orderId], references: [id])
  user             User               @relation(fields: [userId], references: [id])

  @@index([orderId], map: "Penerimaan_orderId_fkey")
  @@index([userId], map: "Penerimaan_userId_fkey")
}

model DetailPenerimaan {
  id           Int        @id @default(autoincrement())
  penerimaanId Int
  barangId     Int
  jumlah       Int
  hargaBeli    Decimal
  subtotal     Decimal
  batch        String?
  expired      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barang       Barang     @relation(fields: [barangId], references: [id])
  penerimaan   Penerimaan @relation(fields: [penerimaanId], references: [id])

  @@index([barangId], map: "DetailPenerimaan_barangId_fkey")
  @@index([penerimaanId], map: "DetailPenerimaan_penerimaanId_fkey")
}

model transaksiBarang {
  id            Int                 @id @default(autoincrement())
  barangId      Int
  tanggal       DateTime            @default(now())
  userId        Int
  transaksiType TransaksiBarangType
  remark        String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id])
  barang        Barang              @relation(fields: [barangId], references: [id])

  @@index([barangId], map: "transaksiBarang_barangId_fkey")
  @@index([userId], map: "transaksiBarang_userId_fkey")
}

model StockOpname {
  id                 Int                 @id @default(autoincrement())
  tanggal            DateTime            @default(now())
  userId             Int
  remark             String?
  user               User                @relation(fields: [userId], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  detailStockOpnames DetailStockOpname[]

  @@index([userId], map: "StockOpname_userId_fkey")
}

model DetailStockOpname {
  id             Int             @id @default(autoincrement())
  stockOpnameId  Int
  barangId       Int
  countQty       Int
  dbQty          Int
  selisih        Int
  adjustmentType StokcOpnameType
  remark         String?
  stockOpname    StockOpname     @relation(fields: [stockOpnameId], references: [id])
  barang         Barang          @relation(fields: [barangId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barangId], map: "DetailStockOpname_barangId_fkey")
  @@index([stockOpnameId], map: "DetailStockOpname_stockOpnameId_fkey")
}

model Lokasi {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Barang    Barang[]
  stok      Stok[]
}

model Stok {
  id        Int      @id @default(autoincrement())
  barangId  Int
  lokasiId  Int
  jumlah    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barang    Barang   @relation(fields: [barangId], references: [id])
  lokasi    Lokasi   @relation(fields: [lokasiId], references: [id])

  @@unique([barangId, lokasiId])
  @@index([lokasiId], map: "Stok_lokasiId_fkey")
}

model image {
  id   Int    @id @default(autoincrement())
  hash String @unique
  name String
  data Bytes
}

enum StatusOrder {
  open
  proses
  terima
  jatuh_tempo
  close
  cancel
}

enum StatusPenerimaan {
  open
  terima
  close
  terbayar
  cancel
  jatuh_tempo
  paid
}

enum UserStatus {
  active
  inactive
  suspended
  password_reset
  deleted
}

enum StokcOpnameType {
  masuk
  keluar
  scrape
  expired
  minusQtyAdjusment
  initialQty
  qtyAdjusment
  countingQty
}

enum TransaksiBarangType {
  masuk
  keluar
  penjualan
  adjustment
  scraping
  expired
  retur
}

enum PaymentType{
  cash
  debit
  transfer
}